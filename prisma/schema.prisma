// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ToolType {
  self_hosted
  saas
  cli
  desktop
  mobile
  api
  library
  browser_extension
  devtool
  other
}

enum ToolStatus {
  to_test
  tested
  recommended
  abandoned
  watching
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  tools       Tool[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("categories")
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  tools     ToolTag[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("tags")
}

model Tool {
  id               String     @id @default(cuid())
  title            String
  slug             String     @unique
  websiteUrl       String?
  githubUrl        String?
  docsUrl          String?
  demoUrl          String?
  shortDescription String
  longDescription  String?
  imageUrl         String?
  categoryId       String?
  category         Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags             ToolTag[]
  type             ToolType   @default(other)
  license          String?
  pricing          String?
  status           ToolStatus @default(to_test)
  personalScore    Int?
  publicNotes      String?
  isFavorite       Boolean    @default(false)
  isRecommended    Boolean    @default(false)
  isSelfHosted     Boolean    @default(false)
  hasDocker        Boolean    @default(false)
  isOpenSource     Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@map("tools")
}

model ToolTag {
  tool   Tool   @relation(fields: [toolId], references: [id], onDelete: Cascade)
  toolId String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  String

  @@id([toolId, tagId])
  @@map("tool_tags")
}
